# Secrets / env
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
.venv/
venv/

# Logs / transient output
*.log
logs/
*.tmp

# Browser automation profiles (huge, contain cookies/cache)
.nodriver-profile/
.nodriver-profile-*/
.playwright-profile/
.playwright-profile-*/
.playwright/

# Scraper debug dumps (raw HTML, regenerated on demand)
dd_debug.html
fz_debug.html
dd_detail_probe.html
fz_detail_probe.html
fz_project_debug.html

# Node / Next.js
node_modules/
web/.next/
web/out/
web/tsconfig.tsbuildinfo

# Vercel local link (contains .env.production.local — re-link via `vercel link`)
.vercel/
web/.vercel/

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Claude Code local settings (contains user-specific tokens)
.claude/
