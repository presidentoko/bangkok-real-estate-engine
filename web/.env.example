# --- Required: Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by RSC fetch. Keep out of NEXT_PUBLIC_*.
SUPABASE_SERVICE_KEY=

# Shared secret for /admin/* routes. Generate with: openssl rand -hex 32
# (or in PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_}))
ADMIN_SECRET=

# --- Recommended: site URL for absolute canonical / OG tags ---
# Production: https://www.passionaryestate.com
NEXT_PUBLIC_SITE_URL=

# --- /ask AI chat (Anthropic) ---
# Get a key at https://console.anthropic.com. Without this the /ask endpoint
# returns 503 with a clear message; the rest of the site is unaffected.
ANTHROPIC_API_KEY=

# --- Lead-capture ops notifications + weekly digests ---
# Telegram bot via @BotFather → /newbot. Chat ID = your own user id from
# @userinfobot (or a group ID where the bot is admin).
# Without these, lead capture still works — but you won't get realtime pings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
