# Copy to .env and fill in. Never commit .env.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional. Without it, livability uses Overpass (OpenStreetMap) by default.
# Set LIVABILITY_PROVIDER=google to force Google Places when key is present.
GOOGLE_PLACES_API_KEY=
LIVABILITY_PROVIDER=overpass

# Rotating proxy pool for free Google scraping (scripts/ingest_reviews_proxy.py).
# Comma-separated full proxy URLs — one per VPN endpoint. http(s) works out of
# the box; socks5:// also needs:  pip install "httpx[socks]"
# PROXY_URLS=http://user:pass@host1:8000,http://user:pass@host2:8000

# Slow / human-paced scraping. Bumping the lower bound makes runs noticeably
# safer at the cost of wall-clock time (~3 pages × 8–15s ≈ 30–45s per source).
SCRAPE_MAX_PAGES=5
SCRAPE_DELAY_MIN=8
SCRAPE_DELAY_MAX=15

HEADLESS=true
LOG_LEVEL=INFO

# Underpriced Alert dispatch (optional). Get via @BotFather → /newbot.
# Without this, alerts are still detected and stored — just not pushed.
TELEGRAM_BOT_TOKEN=
